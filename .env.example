# This project is currently a frontend-only prototype using local mock data —
# no environment variables are required to run it locally (npm run dev / npm run build).
#
# The variable below is optional and only affects metadata (Open Graph / canonical
# URLs). If unset, it falls back to http://localhost:3000 in development.
# On Vercel, set this to your production deployment URL (or custom domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
