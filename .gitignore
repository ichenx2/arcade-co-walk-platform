# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
coverage/
playwright-report/
test-results/

# next.js
/.next/
/out/

# production
/build
build/
dist/

# misc
.DS_Store
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# env files (never commit real secrets; .env.example is intentionally tracked)
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code / AI assistant local config, transcripts, and cache
# (never commit local assistant state or session transcripts)
.claude/
.cursor/
*.compact.json
*.transcript.json

# local design references / working screenshots (not part of the shipped app)
design/

# original competition proposal document (kept private)
docs/

